{
  "entities": {
    "User": {
      "title": "User Public Profile",
      "description": "Stores non-sensitive user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "banned"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "isPrivate"]
    },
    "UserSettings": {
      "title": "User Private Settings",
      "description": "Stores sensitive user information and private settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "usageLimitMinutes": { "type": "number" }
      },
      "required": ["email"]
    },
    "Post": {
      "title": "Post",
      "description": "Stores user publications.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "description": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "duration": { "type": "string", "enum": ["24h", "7d", "30d", "permanent"] },
        "expiresAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "mediaUrl", "mediaType", "duration", "status", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Stores comments on posts.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "text", "createdAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Stores metadata for individual or group chats.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["individual", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "name": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["type", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "Stores individual messages within a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video", "poll"] },
        "pollData": { "type": "object" },
        "sharedPostId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "createdAt"]
    },
    "UsageLog": {
      "title": "Usage Log",
      "description": "Tracks daily usage time for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "minutesUsed": { "type": "number" }
      },
      "required": ["userId", "date", "minutesUsed"]
    },
    "Sanction": {
      "title": "Sanction",
      "description": "Stores sanctions applied to users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["warning", "suspension", "expulsion"] },
        "reason": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "createdAt"]
    },
    "FollowRequest": {
      "title": "Follow Request",
      "description": "Stores pending follow requests for private accounts.",
      "type": "object",
      "properties": {
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "requesterPhoto": { "type": "string" },
        "targetId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requesterId", "targetId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles."
    },
    "/users/{userId}/private/settings": {
      "schema": "UserSettings",
      "description": "Private user settings and PII."
    },
    "/users/{userId}/followers/{followerId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" }, "followedAt": { "type": "string", "format": "date-time" } } },
      "description": "List of users following this user."
    },
    "/users/{userId}/following/{followedId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" }, "followedAt": { "type": "string", "format": "date-time" } } },
      "description": "List of users this user is following."
    },
    "/users/{userId}/followRequests/{requesterId}": {
      "schema": "FollowRequest",
      "description": "Pending follow requests for this user."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Global collection of posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific post."
    },
    "/posts/{postId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Users who liked a post."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a chat."
    },
    "/usageLogs/{logId}": {
      "schema": "UsageLog",
      "description": "Daily usage tracking."
    },
    "/sanctions/{sanctionId}": {
      "schema": "Sanction",
      "description": "User sanctions."
    }
  }
}
